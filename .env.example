# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required for Cloud SQL Postgres database connection or Prisma.
DATABASE_URL="postgresql://username:password@hostname:port/database"

# Individual PostgreSQL connection credentials used by the Drizzle DB Pool
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="civic_agent"

# JWT_SECRET: Private key to sign and verify secure session tokens.
JWT_SECRET="super-secure-production-jwt-signing-secret"
